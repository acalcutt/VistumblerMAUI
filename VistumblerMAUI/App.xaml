<?xml version="1.0" encoding="UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:conv="clr-namespace:VistumblerMAUI.Converters"
             x:Class="VistumblerMAUI.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <conv:BoolToStartStopConverter x:Key="BoolToStartStop" />
            <conv:BoolToColorConverter     x:Key="BoolToColor" />
            <conv:IntToProgressConverter   x:Key="IntToProgress" />
            <conv:InvertBoolConverter      x:Key="InvertBool" />
            <conv:IsKmlFormatConverter     x:Key="IsKmlFormat" />
            <conv:IsNotNullOrEmptyConverter x:Key="IsNotNullOrEmpty" />
            <conv:HexToColorConverter       x:Key="HexToColor" />
            <conv:FrequencyToBandConverter  x:Key="FreqToBand" />
            <conv:RunningToColorConverter   x:Key="RunningToColor" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
