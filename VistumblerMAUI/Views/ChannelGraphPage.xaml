<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:VistumblerMAUI.ViewModels"
             xmlns:controls="clr-namespace:VistumblerMAUI.Controls"
             x:DataType="vm:ChannelGraphViewModel"
             x:Class="VistumblerMAUI.Views.ChannelGraphPage"
             Title="Channels">

    <Grid RowDefinitions="Auto,Auto,*,Auto">

        <!-- Shared scan/GPS control bar -->
        <controls:ScanControlBar x:Name="ScanBar" Grid.Row="0" />

        <!-- Band selector + RSSI/percent toggle -->
        <Grid Grid.Row="1" ColumnDefinitions="Auto,*,Auto,Auto" Padding="12,6" ColumnSpacing="8">
            <Label Grid.Column="0" Text="Band" VerticalOptions="Center" />
            <Picker Grid.Column="1"
                    ItemsSource="{Binding BandOptions}"
                    SelectedItem="{Binding SelectedBand}" />
            <Label Grid.Column="2" Text="RSSI" VerticalOptions="Center" />
            <Switch Grid.Column="3" IsToggled="{Binding UseRssi}" VerticalOptions="Center" />
        </Grid>

        <!-- Graph -->
        <GraphicsView x:Name="GraphView" Grid.Row="2" />

        <Label Grid.Row="3" Text="{Binding StatusText}" FontSize="11" TextColor="Gray"
               HorizontalOptions="Center" Padding="8,4" />
    </Grid>

</ContentPage>
