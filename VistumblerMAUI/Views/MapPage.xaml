<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:VistumblerMAUI.ViewModels"
             xmlns:maplibre="clr-namespace:MapLibreNative.Maui.Handlers;assembly=MapLibreNative.Maui.Handlers"
             xmlns:sources="clr-namespace:MapLibreNative.Maui.Handlers.Sources;assembly=MapLibreNative.Maui.Handlers"
             xmlns:layers="clr-namespace:MapLibreNative.Maui.Handlers.Layers;assembly=MapLibreNative.Maui.Handlers"
             x:DataType="vm:MapViewModel"
             x:Class="VistumblerMAUI.Views.MapPage"
             Title="Map">

    <Grid RowDefinitions="*,Auto,Auto">

        <!-- ── MapLibre map ────────────────────────────────────────────── -->
        <maplibre:MapLibreMap
            Grid.Row="0"
            x:Name="Map"
            StyleUrl="{Binding StyleUrl}"
            MyLocationEnabled="True">

            <!-- Live scan APs — source data is updated by MapViewModel.ApsGeoJson -->
            <sources:GeoJsonSource SourceName="ap-source"
                                   FeatureCollection="{Binding ApsGeoJson}" />
            <layers:CircleLayer    SourceName="ap-source"
                                   LayerName="ap-circles"
                                   Properties="{Binding ApLayerProperties}" />

            <!--
                History overlay sources/layers are added imperatively via the controller
                in MapViewModel.OnMapControllerReady() — called from StyleLoaded below.
                This is the correct pattern: XAML declarative sources are committed first,
                then imperative sources are added on the same StyleLoaded callback.
            -->
        </maplibre:MapLibreMap>

        <!-- ── Tap-to-inspect popup ────────────────────────────────────────
             Shown over the bottom of the map when OnMapTappedAsync finds a
             feature (live AP, or any active history/cell layer) under the tap.
        -->
        <Border Grid.Row="0"
                VerticalOptions="End"
                Margin="10,0,10,10"
                Padding="14,12"
                BackgroundColor="White"
                StrokeShape="RoundRectangle 10"
                Stroke="#DDDDDD"
                IsVisible="{Binding IsPopupVisible}">
            <Border.Shadow>
                <Shadow Brush="Black" Opacity="0.25" Radius="12" Offset="0,2" />
            </Border.Shadow>

            <!-- Note: BindingContext stays MapViewModel throughout (not SelectedFeature) so
                 ClosePopupCommand/ViewInApListCommand stay reachable without an ancestor lookup. -->
            <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                  ColumnDefinitions="*,Auto"
                  RowSpacing="2">

                <Label Grid.Row="0" Grid.Column="0"
                       Text="{Binding SelectedFeature.Title}"
                       FontAttributes="Bold" FontSize="16" />
                <Button Grid.Row="0" Grid.Column="1"
                        Text="✕"
                        Command="{Binding ClosePopupCommand}"
                        BackgroundColor="Transparent" TextColor="Gray"
                        Padding="6,0" FontSize="14" />

                <Label Grid.Row="1" Grid.ColumnSpan="2" FontSize="12" TextColor="Gray">
                    <Label.FormattedText>
                        <FormattedString>
                            <Span Text="{Binding SelectedFeature.SourceLabel}" />
                            <Span Text=" • " />
                            <Span Text="{Binding SelectedFeature.Bssid}" />
                        </FormattedString>
                    </Label.FormattedText>
                </Label>

                <Label Grid.Row="2" Grid.ColumnSpan="2" FontSize="12">
                    <Label.FormattedText>
                        <FormattedString>
                            <Span Text="Ch " /><Span Text="{Binding SelectedFeature.Channel}" />
                            <Span Text="  •  " /><Span Text="{Binding SelectedFeature.Authentication}" />
                            <Span Text="/" /><Span Text="{Binding SelectedFeature.Encryption}" />
                        </FormattedString>
                    </Label.FormattedText>
                </Label>

                <Label Grid.Row="3" Grid.ColumnSpan="2" FontSize="12"
                       IsVisible="{Binding SelectedFeature.Manufacturer, Converter={StaticResource IsNotNullOrEmpty}}"
                       Text="{Binding SelectedFeature.Manufacturer, StringFormat='Manufacturer: {0}'}" />

                <Button Grid.Row="4" Grid.ColumnSpan="2"
                        Text="View in AP List"
                        Margin="0,8,0,0"
                        IsVisible="{Binding SelectedFeature.HasLocalRecord}"
                        Command="{Binding ViewInApListCommand}" />
            </Grid>
        </Border>

        <!-- ── History overlay toggle bar ────────────────────────────────
             Six small buttons (Daily, Weekly, Monthly, < 1 yr, 1–2 yr, Cells)
             that mirror the layer button bar in vistumbler-android VectorMapActivity.
             Active = blue; idle = light gray.  Loading = dimmed + disabled.
        -->
        <ScrollView Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalScrollBarVisibility="Never"
                    BackgroundColor="#F5F5F5">
            <FlexLayout BindableLayout.ItemsSource="{Binding HistoryLayers}"
                        Direction="Row"
                        Wrap="NoWrap"
                        AlignItems="Center"
                        Padding="6,3">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="vm:HistoryLayerState">
                        <Button Text="{Binding Label}"
                                Command="{Binding ToggleCommand}"
                                Padding="10,4"
                                Margin="2,0"
                                CornerRadius="4"
                                FontSize="11"
                                BackgroundColor="#E0E0E0"
                                TextColor="#424242">
                            <Button.Triggers>
                                <!-- Active: Vistumbler blue fill, white text -->
                                <DataTrigger TargetType="Button"
                                             Binding="{Binding IsActive}"
                                             Value="True">
                                    <Setter Property="BackgroundColor" Value="#1565C0" />
                                    <Setter Property="TextColor"       Value="White" />
                                </DataTrigger>
                                <!-- Loading: dimmed + disabled -->
                                <DataTrigger TargetType="Button"
                                             Binding="{Binding IsLoading}"
                                             Value="True">
                                    <Setter Property="Opacity"    Value="0.45" />
                                    <Setter Property="IsEnabled"  Value="False" />
                                </DataTrigger>
                            </Button.Triggers>
                        </Button>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </FlexLayout>
        </ScrollView>

        <!-- ── Status label ──────────────────────────────────────────────── -->
        <Label Grid.Row="2"
               Text="{Binding StatusMessage}"
               HorizontalOptions="Center"
               FontSize="11"
               TextColor="Gray"
               Padding="8,3" />

    </Grid>

</ContentPage>
