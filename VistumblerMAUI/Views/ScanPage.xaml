<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:VistumblerMAUI.ViewModels"
             xmlns:models="clr-namespace:Vistumbler.Core.Models;assembly=Vistumbler.Core"
             xmlns:controls="clr-namespace:VistumblerMAUI.Controls"
             x:DataType="vm:ScanViewModel"
             x:Class="VistumblerMAUI.Views.ScanPage"
             Title="Scan">

    <Grid RowDefinitions="Auto,Auto,*,Auto">

        <!-- Shared scan/GPS control bar (also shown on the other tabs) -->
        <controls:ScanControlBar Grid.Row="0" />

        <!-- Search bar + sort controls + clear -->
        <Grid Grid.Row="1" ColumnDefinitions="*,Auto,Auto,Auto" Padding="8,4" ColumnSpacing="6">
            <SearchBar Grid.Column="0"
                       Text="{Binding SearchText}"
                       Placeholder="Search SSID, BSSID, manufacturer…" />
            <Picker Grid.Column="1"
                    Title="Sort"
                    WidthRequest="120"
                    VerticalOptions="Center"
                    ItemsSource="{Binding SortOptions}"
                    SelectedItem="{Binding SelectedSortOption}" />
            <Button Grid.Column="2"
                    Text="{Binding SortDirectionGlyph}"
                    Command="{Binding ToggleSortDirectionCommand}"
                    WidthRequest="44"
                    Padding="0"
                    VerticalOptions="Center"
                    BackgroundColor="Transparent"
                    TextColor="{AppThemeBinding Light=#1565C0, Dark=#90CAF9}" />
            <Button Grid.Column="3"
                    Text="Clear"
                    Command="{Binding ClearAllCommand}"
                    Padding="8,0"
                    VerticalOptions="Center"
                    BackgroundColor="Transparent"
                    TextColor="#B00020" FontSize="13" />
        </Grid>

        <!-- AP list -->
        <CollectionView Grid.Row="2"
                        ItemsSource="{Binding AccessPoints}"
                        SelectionMode="Single"
                        SelectionChanged="OnApSelected">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:AccessPoint">
                    <Grid ColumnDefinitions="*,Auto,Auto" Padding="12,8" ColumnSpacing="8">
                        <Grid.Triggers>
                            <!-- Dead (not re-seen within the timeout) APs are dimmed but stay listed. -->
                            <DataTrigger TargetType="Grid" Binding="{Binding IsActive}" Value="False">
                                <Setter Property="Opacity" Value="0.4" />
                            </DataTrigger>
                        </Grid.Triggers>
                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                            <Label Text="{Binding Ssid}" FontAttributes="Bold" FontSize="14" />
                            <Label Text="{Binding Bssid}" FontSize="11" TextColor="Gray" />
                            <Label Text="{Binding Manufacturer}" FontSize="11" TextColor="Gray"
                                   IsVisible="{Binding Manufacturer, Converter={StaticResource IsNotNullOrEmpty}}" />
                            <Label FontSize="10" TextColor="Gray" Text="{Binding FirstSeenText, StringFormat='First: {0}'}" />
                            <Label FontSize="10" TextColor="Gray" Text="{Binding LastSeenText, StringFormat='Last: {0}'}" />
                            <Label FontSize="10" TextColor="Gray"
                                   Text="{Binding GpsText, StringFormat='⌖ {0}'}"
                                   IsVisible="{Binding HasGps}" />
                        </VerticalStackLayout>
                        <!-- Signal % + RSSI -->
                        <VerticalStackLayout Grid.Column="1" WidthRequest="64" HorizontalOptions="Center" VerticalOptions="Center" Spacing="2">
                            <Label Text="{Binding Signal, StringFormat='{0}%'}" HorizontalOptions="Center" FontSize="13" />
                            <ProgressBar Progress="{Binding Signal, Converter={StaticResource IntToProgress}}" HeightRequest="6" />
                            <Label Text="{Binding Rssi, StringFormat='{0} dBm'}" HorizontalOptions="Center" FontSize="10" TextColor="Gray" />
                        </VerticalStackLayout>
                        <!-- Channel + band + security (authentication AND encryption) -->
                        <VerticalStackLayout Grid.Column="2" WidthRequest="96" HorizontalOptions="End" VerticalOptions="Center" Spacing="2">
                            <Label Text="{Binding Channel, StringFormat='Ch {0}'}" FontSize="12" HorizontalOptions="End" />
                            <Label Text="{Binding FrequencyMhz, Converter={StaticResource FreqToBand}}" FontSize="10" TextColor="Gray" HorizontalOptions="End" />
                            <Label Text="{Binding AuthText}" FontSize="10" TextColor="#546E7A" HorizontalOptions="End" LineBreakMode="TailTruncation" />
                            <Label Text="{Binding EncryptionText}" FontSize="10" TextColor="#78909C" HorizontalOptions="End" />
                        </VerticalStackLayout>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Bottom hint -->
        <Label Grid.Row="3" Text="Tap Scan APs to begin" HorizontalOptions="Center"
               FontSize="12" TextColor="Gray" Padding="8"
               IsVisible="{Binding IsScanning, Converter={StaticResource InvertBool}}" />
    </Grid>

</ContentPage>
