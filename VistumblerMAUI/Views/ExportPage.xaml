<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:VistumblerMAUI.ViewModels"
             x:DataType="vm:ExportViewModel"
             x:Class="VistumblerMAUI.Views.ExportPage"
             Title="Export">

    <ScrollView>
        <VerticalStackLayout Spacing="0" Padding="0,8">

            <Label Text="FORMAT" Style="{StaticResource SectionHeader}" />
            <Picker Margin="16,0"
                    ItemsSource="{Binding Formats}"
                    SelectedItem="{Binding SelectedFormat}" />
            <BoxView HeightRequest="1" Color="#EEEEEE" Margin="16,8" />

            <Label Text="FILE NAME" Style="{StaticResource SectionHeader}" />
            <Entry Margin="16,0" Text="{Binding FileName}" Placeholder="vistumbler_export" />
            <BoxView HeightRequest="1" Color="#EEEEEE" Margin="16,8" />

            <!-- KML-only options -->
            <StackLayout IsVisible="{Binding SelectedFormat, Converter={StaticResource IsKmlFormat}}">
                <Label Text="KML OPTIONS" Style="{StaticResource SectionHeader}" />
                <Grid ColumnDefinitions="*,Auto" Padding="16,8">
                    <Label Grid.Column="0" Text="Include open networks" VerticalOptions="Center" />
                    <Switch Grid.Column="1" IsToggled="{Binding IncludeOpenNetworks}" />
                </Grid>
                <Grid ColumnDefinitions="*,Auto" Padding="16,8">
                    <Label Grid.Column="0" Text="Include WEP networks" VerticalOptions="Center" />
                    <Switch Grid.Column="1" IsToggled="{Binding IncludeWepNetworks}" />
                </Grid>
                <Grid ColumnDefinitions="*,Auto" Padding="16,8">
                    <Label Grid.Column="0" Text="Include secure networks" VerticalOptions="Center" />
                    <Switch Grid.Column="1" IsToggled="{Binding IncludeSecureNetworks}" />
                </Grid>
                <Grid ColumnDefinitions="*,Auto" Padding="16,8">
                    <Label Grid.Column="0" Text="Colour pins by signal" VerticalOptions="Center" />
                    <Switch Grid.Column="1" IsToggled="{Binding UseSignalColors}" />
                </Grid>
                <BoxView HeightRequest="1" Color="#EEEEEE" Margin="16,8" />
            </StackLayout>

            <!-- Track-capable formats (KML/GPX) -->
            <StackLayout IsVisible="{Binding SelectedFormat, Converter={StaticResource IsTrackFormat}}">
                <Grid ColumnDefinitions="*,Auto" Padding="16,8">
                    <Label Grid.Column="0" Text="Include GPS track" VerticalOptions="Center" />
                    <Switch Grid.Column="1" IsToggled="{Binding IncludeGpsTrack}" />
                </Grid>
                <BoxView HeightRequest="1" Color="#EEEEEE" Margin="16,8" />
            </StackLayout>

            <Button Text="Export"
                    Command="{Binding ExportCommand}"
                    Margin="16,16,16,4"
                    HorizontalOptions="Fill" />

            <Button Text="Cancel"
                    Command="{Binding CancelCommand}"
                    Margin="16,0,16,8"
                    HorizontalOptions="Fill"
                    BackgroundColor="Transparent"
                    TextColor="Gray" />

            <ActivityIndicator IsRunning="{Binding IsExporting}" IsVisible="{Binding IsExporting}" Margin="16,0" />

            <Label Text="{Binding StatusMessage}"
                   FontSize="12" TextColor="Gray"
                   Margin="16,8" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
