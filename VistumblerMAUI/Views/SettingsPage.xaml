<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:VistumblerMAUI.ViewModels"
             xmlns:controls="clr-namespace:VistumblerMAUI.Controls"
             x:DataType="vm:SettingsViewModel"
             x:Class="VistumblerMAUI.Views.SettingsPage"
             Title="Settings">

    <Grid RowDefinitions="Auto,*">
        <controls:ScanControlBar x:Name="ScanBar" Grid.Row="0" />

        <ScrollView Grid.Row="1">
        <VerticalStackLayout Spacing="0" Padding="0,8">

            <!-- Scanning -->
            <Label Text="SCANNING" Style="{StaticResource SectionHeader}" />
            <Grid ColumnDefinitions="*,Auto" Padding="16,12" ColumnSpacing="12">
                <Label Grid.Column="0" Text="Scan interval (ms)" VerticalOptions="Center" />
                <Entry Grid.Column="1" Text="{Binding ScanIntervalMs}" Keyboard="Numeric" WidthRequest="80" />
            </Grid>
            <BoxView HeightRequest="1" Color="#EEEEEE" Margin="16,0" />

            <!-- Map -->
            <Label Text="MAP" Style="{StaticResource SectionHeader}" />
            <Grid ColumnDefinitions="Auto,*" Padding="16,12" ColumnSpacing="12">
                <Label Grid.Column="0" Text="Basemap style" VerticalOptions="Center" />
                <Picker Grid.Column="1"
                        ItemsSource="{Binding MapStyleOptions}"
                        SelectedItem="{Binding SelectedMapStyle}" />
            </Grid>
            <Entry Margin="16,0,16,8"
                   IsVisible="{Binding IsCustomMapStyle}"
                   Text="{Binding CustomMapStyleUrl}"
                   Placeholder="https://…/style.json"
                   Keyboard="Url" />
            <BoxView HeightRequest="1" Color="#EEEEEE" Margin="16,0" />

            <!-- Map AP colors -->
            <Label Text="MAP AP COLORS" Style="{StaticResource SectionHeader}" />
            <Label Margin="16,0,16,4" FontSize="12" TextColor="Gray"
                   Text="Circle colors per age bucket, by security type (hex RRGGBB). The live scan's active APs are brightest; dead and older buckets darken with age." />
            <Grid ColumnDefinitions="110,*,*,*" Padding="16,0,16,2" ColumnSpacing="6">
                <Label Grid.Column="0" Text="Bucket"  FontSize="11" FontAttributes="Bold" />
                <Label Grid.Column="1" Text="Open"    FontSize="11" FontAttributes="Bold" />
                <Label Grid.Column="2" Text="WEP"     FontSize="11" FontAttributes="Bold" />
                <Label Grid.Column="3" Text="Secure"  FontSize="11" FontAttributes="Bold" />
            </Grid>
            <VerticalStackLayout BindableLayout.ItemsSource="{Binding MapBucketColors}" Spacing="0">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="vm:MapBucketColorRow">
                        <Grid ColumnDefinitions="110,*,*,*" Padding="16,2" ColumnSpacing="6">
                            <Label Grid.Column="0" Text="{Binding DisplayName}" FontSize="12" VerticalOptions="Center" />
                            <HorizontalStackLayout Grid.Column="1" Spacing="4">
                                <Entry Text="{Binding OpenHex}" WidthRequest="66" FontSize="12" MaxLength="6" />
                                <BoxView WidthRequest="14" HeightRequest="18" VerticalOptions="Center"
                                         Color="{Binding OpenHex, Converter={StaticResource HexToColor}}" />
                            </HorizontalStackLayout>
                            <HorizontalStackLayout Grid.Column="2" Spacing="4">
                                <Entry Text="{Binding WepHex}" WidthRequest="66" FontSize="12" MaxLength="6" />
                                <BoxView WidthRequest="14" HeightRequest="18" VerticalOptions="Center"
                                         Color="{Binding WepHex, Converter={StaticResource HexToColor}}" />
                            </HorizontalStackLayout>
                            <HorizontalStackLayout Grid.Column="3" Spacing="4">
                                <Entry Text="{Binding SecureHex}" WidthRequest="66" FontSize="12" MaxLength="6" />
                                <BoxView WidthRequest="14" HeightRequest="18" VerticalOptions="Center"
                                         Color="{Binding SecureHex, Converter={StaticResource HexToColor}}" />
                            </HorizontalStackLayout>
                        </Grid>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>
            <BoxView HeightRequest="1" Color="#EEEEEE" Margin="16,8,16,0" />

            <!-- Notifications -->
            <Label Text="NOTIFICATIONS" Style="{StaticResource SectionHeader}" />
            <Grid ColumnDefinitions="*,Auto" Padding="16,12">
                <Label Grid.Column="0" Text="Sound alerts" VerticalOptions="Center" />
                <Switch Grid.Column="1" IsToggled="{Binding SoundEnabled}" />
            </Grid>
            <BoxView HeightRequest="1" Color="#EEEEEE" Margin="16,0" />

            <!-- GPS -->
            <Label Text="GPS" Style="{StaticResource SectionHeader}" />
            <Grid ColumnDefinitions="Auto,*" Padding="16,8" ColumnSpacing="12">
                <Label Grid.Column="0" Text="GPS source" VerticalOptions="Center" />
                <Picker Grid.Column="1"
                        ItemsSource="{Binding GpsSourceOptions}"
                        SelectedItem="{Binding SelectedGpsSource}" />
            </Grid>
            <!-- Serial (NMEA) settings, shown only when the serial source is selected -->
            <VerticalStackLayout IsVisible="{Binding IsSerialGps}" Padding="16,0,16,8" Spacing="8">
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                    <Label Grid.Column="0" Text="COM port" VerticalOptions="Center" />
                    <Picker Grid.Column="1"
                            ItemsSource="{Binding ComPorts}"
                            SelectedItem="{Binding SelectedComPort}" />
                    <Button Grid.Column="2" Text="Refresh"
                            Command="{Binding RefreshComPortsCommand}"
                            Padding="10,4" FontSize="12" />
                </Grid>
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                    <Label Grid.Column="0" Text="Baud rate" VerticalOptions="Center" />
                    <Picker Grid.Column="1"
                            ItemsSource="{Binding BaudRateOptions}"
                            SelectedItem="{Binding SelectedBaudRate}" />
                </Grid>
                <Label Text="Serial NMEA is Windows-only. Choose the COM port your GPS receiver uses."
                       FontSize="11" TextColor="Gray" />
            </VerticalStackLayout>
            <BoxView HeightRequest="1" Color="#EEEEEE" Margin="16,0" />

            <!-- WifiDB -->
            <Label Text="WIFIDB" Style="{StaticResource SectionHeader}" />
            <Grid ColumnDefinitions="Auto,*" Padding="16,8" ColumnSpacing="12" RowSpacing="8"
                  RowDefinitions="Auto,Auto,Auto">
                <Label Grid.Row="0" Grid.Column="0" Text="Base URL" VerticalOptions="Center" />
                <Entry Grid.Row="0" Grid.Column="1" Text="{Binding WifiDbUrl}"
                       Placeholder="https://wifidb.net/" Keyboard="Url" />

                <Label Grid.Row="1" Grid.Column="0" Text="Username" VerticalOptions="Center" />
                <Entry Grid.Row="1" Grid.Column="1" Text="{Binding WifiDbUser}" Placeholder="username" />

                <Label Grid.Row="2" Grid.Column="0" Text="API key" VerticalOptions="Center" />
                <Entry Grid.Row="2" Grid.Column="1" Text="{Binding WifiDbApiKey}"
                       Placeholder="API key" IsPassword="True" />
            </Grid>

            <Button Text="Register with QR code"
                    Command="{Binding ScanWifiDbQrCommand}"
                    Margin="16,4" HorizontalOptions="Fill" />
            <Button Text="Register with link…"
                    Command="{Binding RedeemWifiDbLinkCommand}"
                    Margin="16,0,16,4" HorizontalOptions="Fill"
                    BackgroundColor="Transparent" TextColor="#1565C0" />
            <Label Text="{Binding WifiDbStatus}"
                   IsVisible="{Binding WifiDbStatus, Converter={StaticResource IsNotNullOrEmpty}}"
                   FontSize="12" TextColor="Gray" Margin="16,0,16,4" />
            <BoxView HeightRequest="1" Color="#EEEEEE" Margin="16,4" />

            <!-- Data -->
            <Label Text="DATA" Style="{StaticResource SectionHeader}" />
            <Button Text="Import…"
                    Command="{Binding GoToImportCommand}"
                    Margin="16,8" HorizontalOptions="Fill" />
            <Button Text="Export…"
                    Command="{Binding GoToExportCommand}"
                    Margin="16,4" HorizontalOptions="Fill" />

            <!-- Advanced -->
            <Label Text="ADVANCED" Style="{StaticResource SectionHeader}" />
            <Grid ColumnDefinitions="*,Auto" Padding="16,8">
                <Label Grid.Column="0" Text="Keep screen on while scanning" VerticalOptions="Center" />
                <Switch Grid.Column="1" IsToggled="{Binding KeepScreenOn}" />
            </Grid>
            <Grid ColumnDefinitions="*,Auto" Padding="16,8">
                <Label Grid.Column="0" Text="Debug logging" VerticalOptions="Center" />
                <Switch Grid.Column="1" IsToggled="{Binding DebugLogging}" />
            </Grid>
            <Label Text="Writes GPS fixes and map layer refreshes to the debug log (adb logcat) for troubleshooting."
                   FontSize="11" TextColor="Gray" Margin="16,0,16,8" />

        </VerticalStackLayout>
        </ScrollView>
    </Grid>

</ContentPage>
